# ─────────────────────────────────────────────────────────────────────────────
# Nexus Platform — Root Environment Template
#
# Copy this file to .env and fill in every value before running
# docker compose -f docker-compose.production.yml up.
#
# Backend-specific variables (non-Docker) are in backend/.env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=nexus_prod
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
# When set, Redis will enforce --requirepass in production Compose.
REDIS_PASSWORD=change_me_redis_password

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_64_char_random_string_here_____________________________
JWT_REFRESH_SECRET=change_me_64_char_random_refresh_secret_here______________

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
# Comma-separated allowed CORS origins
FRONTEND_URLS=https://your-domain.com
LOG_LEVEL=info
APP_VERSION=1.0.0

# ── AWS S3 / Compatible Storage ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=nexus-prod-files
S3_ENDPOINT=
CDN_URL=

# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# Backend DSN — leave empty to disable Sentry in backend
SENTRY_DSN=
# Sample rate 0.0–1.0 (default: 0.1 = 10 %)
SENTRY_TRACES_RATE=0.1

# ── Frontend build-time vars (Vite) ──────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_SENTRY_TRACES_RATE=0.1
VITE_APP_VERSION=1.0.0

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_password

# ── Frontend / Nginx ─────────────────────────────────────────────────────────
REACT_APP_API_URL=https://api.your-domain.com
REACT_APP_WS_URL=wss://api.your-domain.com
